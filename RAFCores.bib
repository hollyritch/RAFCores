  pages = {503--03},
  urldate = {2025-11-01},
  abstract = {Autocatalysis---molecules catalyzing the formation of their own copies---is a central concept to the emergence of life, both terrestrial and non-terrestrial. Not only does such a process represent a possible precursor for biological life able to grow and reproduce, but spontaneous autocatalytic syntheses can also plausibly stock a primordial environment with usable organic matter starting from simple ubiquitous materials. Furthermore, autocatalysis may solve the problem of chemical reaction networks commonly forming unusable mixtures of compounds. Arguably, all living beings are autocatalytic in nature by virtue of consuming matter and transforming it into more of themselves. Due to the eminent importance of autocatalysis to primordial chemistry, biochemistry and the transition between the two, we devised an algorithm to locate autocatalytic cycles in chemical reaction networks. In contrast to previously existing reachability-based or flow-based implementations, our approach focuses on the necessary graph-topological features imposed on the network by the concept of self-copying. In addition, we present the destructive counterpart of autocatalysis. We report on up to thousands of new autocatalytic cycles located in large-scale metabolic networks spanning across multiple pathways. Furthermore, we show how shifting perspective from molecules to functional groups can induce a shadow network of autocatalysis that usually goes unnoticed.},
  annotation = {ADS Bibcode: 2022absc.conf50303H}
}

